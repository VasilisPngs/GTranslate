{
  "manifest_version": 3,
  "name": "GTranslate",
  "version": "1.0",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [],
  "host_permissions": [
    "*://translate.googleapis.com/*"
  ],
  "background": {
    "service_worker": "bg.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["c.js"],
      "css": ["s.css"],
      "all_frames": true
    }
  ]
}